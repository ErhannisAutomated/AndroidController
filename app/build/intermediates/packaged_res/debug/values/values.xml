<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="bg_dark">#1A1A2E</color>
    <color name="btn_a">#4CAF50</color>
    <color name="btn_b">#F44336</color>
    <color name="btn_dpad">#0F3460</color>
    <color name="btn_menu">#37474F</color>
    <color name="btn_shoulder">#0F3460</color>
    <color name="btn_trigger">#0A2647</color>
    <color name="btn_x">#2196F3</color>
    <color name="btn_y">#FFC107</color>
    <color name="dpad_center">#0F3460</color>
    <color name="surface">#16213E</color>
    <color name="text_primary">#E0E0E0</color>
    <color name="text_secondary">#9E9E9E</color>
    <string name="app_name">BT Gamepad</string>
    <string name="status_connected">Connected</string>
    <string name="status_disconnected">Disconnected</string>
    <string name="status_initialising">Initialising…</string>
    <string name="status_waiting">Waiting for host to connect…</string>
    <style name="Theme.AndroidController" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/btn_a</item>
        <item name="colorPrimaryVariant">@color/surface</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>
    <style name="Widget.AndroidController.ButtonBase" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">4dp</item>
    </style>
    <style name="Widget.AndroidController.DpadButton" parent="Widget.AndroidController.ButtonBase">
        <item name="android:backgroundTint">@color/btn_dpad</item>
        <item name="android:textSize">18sp</item>
        <item name="cornerRadius">4dp</item>
    </style>
    <style name="Widget.AndroidController.FaceButton" parent="Widget.AndroidController.ButtonBase">
        <item name="android:textSize">18sp</item>
        <item name="cornerRadius">30dp</item>
    </style>
    <style name="Widget.AndroidController.MenuButton" parent="Widget.AndroidController.ButtonBase">
        <item name="android:backgroundTint">@color/btn_menu</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">18dp</item>
    </style>
    <style name="Widget.AndroidController.ShoulderButton" parent="Widget.AndroidController.ButtonBase">
        <item name="android:backgroundTint">@color/btn_shoulder</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">6dp</item>
    </style>
    <style name="Widget.AndroidController.TriggerButton" parent="Widget.AndroidController.ButtonBase">
        <item name="android:backgroundTint">@color/btn_trigger</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">6dp</item>
    </style>
</resources>